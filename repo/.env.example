APP_DEBUG = false

; Generate with: openssl rand -base64 48
; Both keys MUST be set (min 32 chars) — application refuses to start otherwise.
APP_KEY =
HMAC_KEY =

[APP]
DEFAULT_TIMEZONE = America/New_York

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = precision_portal
USERNAME = root
PASSWORD =
HOSTPORT = 3306
CHARSET = utf8mb4
PREFIX = pp_
DEBUG = false

[SESSION]
TYPE = file
EXPIRE = 900

[LANG]
default_lang = en-us
